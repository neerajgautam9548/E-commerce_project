    let count = 1;

    function updateUI() {
      document.getElementById("count").innerText =
        count.toString().padStart(2, "0");
    }

    function increase() {
      count++;
      updateUI();
    }

    function decrease() {
      if (count > 1) {
        count--;
        updateUI();
      }
    }
  </script> -->

    <%- include('./partials/footer') %>